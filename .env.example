# Clé API Anthropic — UNIQUEMENT côté serveur (jamais exposée au client, jamais committée).
# En local : copier ce fichier vers .env.local et renseigner la vraie valeur.
# En prod  : définir la variable dans le dashboard Vercel (Project Settings → Environment Variables).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Garde-fous de dépense (optionnels — valeurs par défaut codées dans lib/config.ts)
DAILY_BUDGET_EUR=10
PER_EMAIL_DAILY_QUOTA=10

# Store managé des compteurs (dépense du jour + quotas par email).
# En prod : fourni par l'intégration Vercel KV / Upstash Redis (Marketplace).
# En local : laisser vide → fallback fichier .data/store.json (dev uniquement, non versionné).
KV_REST_API_URL=
KV_REST_API_TOKEN=
