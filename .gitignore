# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local KV fallback store (dev only)
/.data

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Outillage d'agent (contenu tiers, non lié au produit) — cf. docs/DECISIONS.md D24
/.agents/
/skills-lock.json

# Briefs de travail internes (méthode AMO/MOE, hors vitrine pour l'instant)
/brief-*.md

# Sources de design non servies au runtime (réservoir local, hors /public)
/design/
